# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Sentry DSN для мониторинга ошибок (опционально)
SENTRY_DSN=

# Окружение: development | production
ENVIRONMENT=development

# Уровень логов: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Путь к базе данных
DATABASE_PATH=bot_data.db

# Таймаут теста в секундах (по умолчанию 20 минут)
TEST_TIME_LIMIT=1200

# === Только для PythonAnywhere (webhook режим) ===
# Твой username на PythonAnywhere (без .pythonanywhere.com)
PYTHONANYWHERE_USERNAME=

# Секретный токен в URL webhook (любая случайная строка)
WEBHOOK_SECRET=change_me_to_random_string
